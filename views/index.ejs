<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Registration Portal</title>

    <link rel="stylesheet" href="/style.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                Student Registration Portal
            </a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container text-center">
            <h1>Welcome Students 👋</h1>
            <p>Register your details through our modern portal.</p>
        </div>
    </section>

    <!-- Features -->
    <section class="container my-5">
        <div class="row">

            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Fast</h3>
                    <p>Quick and simple registration.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Secure</h3>
                    <p>Validated form submission.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Responsive</h3>
                    <p>Works on mobile and desktop.</p>
                </div>
            </div>

        </div>
    </section>

    <!-- Registration Form -->
    <div class="container form-section">

        <h2 class="text-center mb-4">
            Student Registration Form
        </h2>

        <form action="/submit" method="POST" onsubmit="return validateForm()">

            <input type="text"
                id="name"
                name="name"
                placeholder="Enter Full Name"
                required>
            <small id="welcomeText"></small>

            <input type="email"
                id="email"
                name="email"
                placeholder="Enter Email"
                required>

            <input type="tel"
                id="phone"
                name="phone"
                placeholder="Enter Phone Number"
                required>

            <input type="number"
                id="age"
                name="age"
                placeholder="Enter Age"
                required>

            <input type="password"
                id="password"
                name="password"
                placeholder="Create Password"
                required>

<small id="passwordStrength"></small>

            <select id="department"
                name="department"
                required>

                <option value="">Select Department</option>
                <option>CSE</option>
                <option>AI&DS</option>
                <option>ECE</option>
                <option>EEE</option>
                <option>MECH</option>

            </select>
            <p id="selectedDepartment"></p>

            <textarea id="message"
                      name="message"
                      placeholder="Enter your message"
                      onkeyup="countCharacters()"></textarea>

            <p>
                Characters:
                <span id="charCount">0</span>
            </p>

            <div class="row mt-3">

    <div class="col-md-6">
        <button type="submit" class="btn btn-primary w-100">
            Register
        </button>
    </div>

    <div class="col-md-6">
        <a href="/users" class="btn btn-success w-100">
            View Users Dashboard
        </a>
    </div>

</div>

        </form>

    </div>
    <section class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="text-center mb-3">
            Weather Search
        </h2>

        <input
            type="text"
            id="city"
            class="form-control"
            placeholder="Enter City Name">

        <button
            class="btn btn-success mt-3"
            onclick="getWeather()">

            Get Weather

        </button>

        <div id="weatherResult" class="mt-3"></div>

    </div>

</section>

    <!-- Footer -->
    <footer>
        <p>© 2026 Student Registration Portal</p>
    </footer>
    <script src="/script.js"></script>

    <script>

function validateForm() {

    let name = document.getElementById("name").value;
    let email = document.getElementById("email").value;
    let phone = document.getElementById("phone").value;
    let age = document.getElementById("age").value;
    let password = document.getElementById("password").value;

    if (name.length < 3) {
        alert("Name must contain at least 3 characters");
        return false;
    }

    if (!email.includes("@")) {
        alert("Enter a valid email");
        return false;
    }

    if (phone.length != 10) {
        alert("Phone number must contain 10 digits");
        return false;
    }

    if (age < 18) {
        alert("Age should be 18 or above");
        return false;
    }

    if (password.length < 8) {
        alert("Password must contain at least 8 characters");
        return false;
    }

    return true;
}

document.getElementById("name")
.addEventListener("keyup", function () {

    document.getElementById("welcomeText").innerHTML =
        "Welcome, " + this.value + " 👋";

});

document.getElementById("department")
.addEventListener("change", function () {

    document.getElementById("selectedDepartment").innerHTML =
        "Selected Department: " + this.value;

});

document.getElementById("password")
.addEventListener("keyup", function () {

    let strength =
        document.getElementById("passwordStrength");

    if (this.value.length < 6) {

        strength.innerHTML = "🔴 Weak Password";
        strength.style.color = "red";

    }

    else if (this.value.length < 10) {

        strength.innerHTML = "🟡 Medium Password";
        strength.style.color = "orange";

    }

    else {

        strength.innerHTML = "🟢 Strong Password";
        strength.style.color = "green";

    }

});

function countCharacters() {

    let text =
        document.getElementById("message").value;

    document.getElementById("charCount").innerHTML =
        text.length;

}

</script>